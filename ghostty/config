# config reload = shift + command + ,
# pane move = cmd + alt + left right up down
background = #031219
# background = #161821
# background = #1F1F1F

background-blur-radius = 20
background-opacity = 0.9
command = /opt/homebrew/bin/fish
cursor-color = "#47FF9C"
font-family = "PlemolJP Console NF Text"
# font-family = "Menlo"

# fontを太くする
# font-thicken = true

font-size = 19

keybind = unconsumed:ctrl+h=goto_split:left
keybind = unconsumed:ctrl+j=goto_split:bottom
keybind = unconsumed:ctrl+k=goto_split:top
keybind = unconsumed:ctrl+l=goto_split:right

theme = "Solarized Darcula"

copy-on-select = true
window-padding-y = 1
window-padding-x = 0
window-position-x = 0
window-position-y = 0
gtk-titlebar-hide-when-maximized = true
window-height = 62
window-width = 235
quit-after-last-window-closed = true
macos-titlebar-style = tabs
mouse-hide-while-typing = true
